# Docker image and port
ASR_IMAGE=local/asr-kit:cuda12
# ASR_IMAGE=local/asr-kit:arm64
ASR_PORT=8000

# Host paths mounted into the container
MODELS_CONFIG_FILE=./config/models.yaml
MODELS_DIR=./models
HF_CACHE_DIR=./hf-cache

# Runtime defaults (cuda + float16 for docker-compose.yml; cpu + int8 for docker-compose.arm.yml)
DEFAULT_DEVICE=cuda
DEFAULT_COMPUTE_TYPE=float16
DEFAULT_LANGUAGE=ru
LOG_LEVEL=INFO

# Model memory management
MODEL_IDLE_TTL_SECONDS=600
MODEL_UNLOAD_INTERVAL_SECONDS=30
MODEL_UNLOAD_AFTER_REQUEST=true
